<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage
    x:Class="SkladTheater.Maui.Views.ProfilePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Профиль">

    <VerticalStackLayout Padding="24" Spacing="16">
        <Image
            Aspect="AspectFill"
            HeightRequest="120"
            HorizontalOptions="Center"
            Source="{Binding AvatarUrl}"
            WidthRequest="120">
            <Image.Clip>
                <EllipseGeometry Center="60,60" RadiusX="60" RadiusY="60" />
            </Image.Clip>
        </Image>

        <Button Command="{Binding PickAvatarCommand}" Text="Сменить фото" />

        <Label FontAttributes="Bold" FontSize="22" HorizontalOptions="Center" Text="{Binding User.DisplayName}" />
        <Label HorizontalOptions="Center" Text="{Binding User.Login}" TextColor="Gray" />
        <Label HorizontalOptions="Center" Text="{Binding User.RoleName}" TextColor="Gray" />

        <Button Command="{Binding LogoutCommand}" Text="Выйти" />

        <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" />
    </VerticalStackLayout>
</ContentPage>
