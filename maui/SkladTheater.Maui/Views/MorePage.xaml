<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage
    x:Class="SkladTheater.Maui.Views.MorePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:SkladTheater.Maui.ViewModels"
    Title="Ещё">

    <CollectionView ItemsSource="{Binding MenuItems}">
        <CollectionView.ItemsLayout>
            <GridItemsLayout Orientation="Vertical" Span="2" />
        </CollectionView.ItemsLayout>
        <CollectionView.ItemTemplate>
            <DataTemplate x:DataType="vm:MenuItem">
                <Border Margin="8" Padding="16">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MoreViewModel}}, Path=NavigateCommand}" CommandParameter="{Binding .}" />
                    </Border.GestureRecognizers>
                    <Label HorizontalOptions="Center" Text="{Binding Title}" />
                </Border>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>
</ContentPage>
