<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage
    x:Class="SkladTheater.Maui.Views.KassetyPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:SkladTheater.Maui.Models"
    Title="Кассеты">

    <Grid RowDefinitions="Auto,*">
        <Label
            Grid.Row="0"
            IsVisible="{Binding StatusMessage, Converter={StaticResource StringNotEmptyConverter}}"
            Text="{Binding StatusMessage}"
            TextColor="OrangeRed" />

        <RefreshView
            Grid.Row="1"
            Command="{Binding LoadCommand}"
            IsRefreshing="{Binding IsBusy}">
            <CollectionView ItemsSource="{Binding Kassety}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:KassetaDto">
                        <Border Margin="8,4" Padding="12">
                            <VerticalStackLayout>
                                <Label FontAttributes="Bold" Text="{Binding Number}" />
                                <Label Text="{Binding Shelf, StringFormat='Полка: {0}'}" TextColor="Gray" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>
    </Grid>
</ContentPage>
