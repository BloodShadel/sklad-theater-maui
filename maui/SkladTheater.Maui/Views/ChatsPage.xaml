<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage
    x:Class="SkladTheater.Maui.Views.ChatsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:SkladTheater.Maui.Models"
    Title="Чат">

    <Grid RowDefinitions="Auto,*">
        <Label
            Grid.Row="0"
            IsVisible="{Binding StatusMessage, Converter={StaticResource StringNotEmptyConverter}}"
            Text="{Binding StatusMessage}"
            TextColor="OrangeRed" />

        <RefreshView
            Grid.Row="1"
            Command="{Binding LoadCommand}"
            IsRefreshing="{Binding IsBusy}">
            <CollectionView ItemsSource="{Binding Chats}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:ChatDto">
                        <Border Margin="8,4" Padding="12">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenChatCommand}" CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>
                            <Grid ColumnDefinitions="*,Auto">
                                <VerticalStackLayout Grid.Column="0">
                                    <Label FontAttributes="Bold" Text="{Binding DisplayName}" />
                                    <Label Text="{Binding LastMessage.Text}" TextColor="Gray" />
                                </VerticalStackLayout>
                                <Label
                                    Grid.Column="1"
                                    IsVisible="{Binding UnreadCount, Converter={StaticResource GreaterThanZeroConverter}}"
                                    Text="{Binding UnreadCount}"
                                    TextColor="Red"
                                    VerticalOptions="Center" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>
    </Grid>
</ContentPage>
