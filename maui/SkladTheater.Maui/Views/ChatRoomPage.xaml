<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage
    x:Class="SkladTheater.Maui.Views.ChatRoomPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:SkladTheater.Maui.Models"
    Title="{Binding ChatName}">

    <Grid RowDefinitions="*,Auto,Auto">
        <CollectionView Grid.Row="0" ItemsSource="{Binding Messages}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:ChatMessageDto">
                    <Border Margin="8,4" Padding="10">
                        <VerticalStackLayout>
                            <Label FontAttributes="Bold" Text="{Binding SenderName}" />
                            <Label Text="{Binding Text}" />
                            <Label FontSize="10" Text="{Binding CreatedAt}" TextColor="Gray" />
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Label
            Grid.Row="1"
            IsVisible="{Binding StatusMessage, Converter={StaticResource StringNotEmptyConverter}}"
            Text="{Binding StatusMessage}"
            TextColor="Red" />

        <Grid Grid.Row="2" ColumnDefinitions="*,Auto" Padding="8">
            <Entry Grid.Column="0" Placeholder="Сообщение" Text="{Binding MessageText}" />
            <Button Grid.Column="1" Command="{Binding SendCommand}" Text="→" />
        </Grid>
    </Grid>
</ContentPage>
