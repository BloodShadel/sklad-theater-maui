<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage
    x:Class="SkladTheater.Maui.Views.GrafikPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:vm="clr-namespace:SkladTheater.Maui.ViewModels"
    Title="График">

    <Grid RowDefinitions="Auto,Auto,*">
        <Entry
            Grid.Row="0"
            Margin="12,8"
            Placeholder="YYYY-MM"
            Text="{Binding Month}" />

        <Button
            Grid.Row="1"
            Margin="12,0"
            Command="{Binding LoadCommand}"
            Text="Загрузить" />

        <RefreshView
            Grid.Row="2"
            Command="{Binding LoadCommand}"
            IsRefreshing="{Binding IsBusy}">
            <CollectionView ItemsSource="{Binding Rows}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:ShiftRow">
                        <Border Margin="8,4" Padding="12">
                            <VerticalStackLayout>
                                <Label FontAttributes="Bold" Text="{Binding UserName}" />
                                <Label Text="{Binding Shifts}" TextColor="Gray" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>
    </Grid>
</ContentPage>
