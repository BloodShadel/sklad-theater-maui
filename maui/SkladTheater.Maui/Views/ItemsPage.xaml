<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage
    x:Class="SkladTheater.Maui.Views.ItemsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:SkladTheater.Maui.Models"
    Title="Предметы">

    <ContentPage.ToolbarItems>
        <ToolbarItem Command="{Binding LogoutCommand}" Text="Выход" />
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="Auto,Auto,*">
        <SearchBar
            Grid.Row="0"
            Placeholder="Поиск предметов"
            Text="{Binding SearchText}" />

        <Label
            Grid.Row="1"
            IsVisible="{Binding StatusMessage, Converter={StaticResource StringNotEmptyConverter}}"
            Text="{Binding StatusMessage}"
            TextColor="OrangeRed" />

        <RefreshView
            Grid.Row="2"
            IsRefreshing="{Binding IsBusy}"
            Command="{Binding LoadCommand}">
            <CollectionView ItemsSource="{Binding Items}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:ItemDto">
                        <Border Padding="12" Margin="8,4">
                            <VerticalStackLayout>
                                <Label FontAttributes="Bold" Text="{Binding Name}" />
                                <Label Text="{Binding Description}" TextColor="Gray" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>
    </Grid>
</ContentPage>
