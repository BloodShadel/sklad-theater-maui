<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="SkladTheater.Maui.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:SkladTheater.Maui.Views"
    Shell.FlyoutBehavior="Disabled"
    Title="SkladTheater.Maui">

    <ShellContent
        Title="Login"
        ContentTemplate="{DataTemplate views:LoginPage}"
        Route="LoginPage" />

    <ShellContent
        Title="Profile"
        ContentTemplate="{DataTemplate views:ProfilePage}"
        Route="ProfilePage"
        FlyoutItemIsVisible="False" />

    <TabBar Route="MainPage">
        <Tab Title="Предметы">
            <ShellContent ContentTemplate="{DataTemplate views:ItemsPage}" />
        </Tab>
        <Tab Title="Задания">
            <ShellContent ContentTemplate="{DataTemplate views:ItemsPage}" />
        </Tab>
        <Tab Title="Сундуки">
            <ShellContent ContentTemplate="{DataTemplate views:ItemsPage}" />
        </Tab>
        <Tab Title="Чат">
            <ShellContent ContentTemplate="{DataTemplate views:ItemsPage}" />
        </Tab>
        <Tab Title="Ещё">
            <ShellContent ContentTemplate="{DataTemplate views:MorePage}" />
        </Tab>
    </TabBar>

</Shell>
